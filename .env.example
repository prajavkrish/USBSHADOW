SECRET_KEY=replace-with-a-long-random-value
DATABASE_URL=sqlite:///usbshadow.db
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Kolkata
USBSHADOW_API=http://127.0.0.1:5000
LARGE_FILE_BYTES=104857600
SENSITIVE_EXTENSIONS=.key,.pem,.pfx,.p12,.kdbx,.docx,.xlsx,.pdf,.sql,.env
REPEATED_CONNECTION_WINDOW_HOURS=24
REPEATED_CONNECTION_THRESHOLD=3
